rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    //
    // Collection: companies
    // Fields: name, slug, password, logo_url, created_at
    //
    // Collection: clothes
    // Fields: company_id, name, type, model, sizes, color, age_group, weather, image_url, section, created_at
    //
    // Collection: collections
    // Fields: company_id, name, event_date, description, image_url, itemIds
    //
    // Collection: clients
    // Fields: company_id, full_name, phone, id_image_url, company_name, company_phone, created_at
    //
    // Collection: rentals
    // Fields: company_id, clothing_id, clothing_name, image_url, client_id, client_name, client_phone, size, color, rental_date, returned_at, status
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "miranluqman60@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidCompany(data) {
      return data.name is string && data.name.size() > 0 &&
             data.slug is string && data.slug.size() > 0 &&
             data.password is string && data.password.size() >= 4;
    }

    function isValidClothing(data) {
      return data.company_id is string &&
             data.name is string && data.name.size() > 0 &&
             data.type is string &&
             data.model is string &&
             data.sizes is list &&
             data.color is string;
    }

    function isValidClient(data) {
      return data.company_id is string &&
             data.full_name is string && data.full_name.size() > 0 &&
             data.phone is string && data.phone.size() > 0;
    }

    function isValidRental(data) {
      return data.company_id is string &&
             data.clothing_id is string &&
             data.client_name is string &&
             data.size is string &&
             data.color is string &&
             data.status in ['active', 'returned'];
    }

    function isValidProject(data) {
      return data.company_id is string && data.name is string && data.name.size() > 0;
    }

    function isValidActor(data) {
      return data.company_id is string && data.project_id is string && data.name is string && data.name.size() > 0;
    }

    function isValidShot(data) {
      return data.company_id is string && data.project_id is string && data.actor_id is string && data.shot_number is number && data.clothing_item_ids is list;
    }

    // Rules
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isValidCompany(request.resource.data);
      allow update, delete: if isSuperAdmin();
    }

    match /clothes/{clothId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /clients/{clientId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /rentals/{rentalId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && isValidProject(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /actors/{actorId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidActor(request.resource.data);
      allow update: if isAuthenticated() && isValidActor(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /shots/{shotId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidShot(request.resource.data);
      allow update: if isAuthenticated() && isValidShot(request.resource.data);
      allow delete: if isAuthenticated();
    }
    
    match /company_secrets/{secretId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
