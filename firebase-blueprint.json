{
  "entities": {
    "Company": {
      "title": "Company",
      "description": "A company account in the system",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "slug": { "type": "string", "description": "URL-friendly name for sharing" },
        "password": { "type": "string" },
        "logo_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "slug", "password"]
    },
    "ClothingItem": {
      "title": "Clothing Item",
      "description": "An item of clothing in the inventory",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "model": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "color": { "type": "string" },
        "age_group": { "type": "string" },
        "weather": { "type": "string" },
        "image_url": { "type": "string" },
        "section": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["company_id", "name", "type", "model", "sizes", "color", "age_group", "weather"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A group of clothing items for an event",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "name": { "type": "string" },
        "event_date": { "type": "string" },
        "description": { "type": "string" },
        "image_url": { "type": "string" },
        "itemIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["company_id", "name"]
    },
    "Client": {
      "title": "Client",
      "description": "A client who rents clothes",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "full_name": { "type": "string" },
        "phone": { "type": "string" },
        "id_image_url": { "type": "string" },
        "company_name": { "type": "string" },
        "company_phone": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["company_id", "full_name", "phone"]
    },
    "Rental": {
      "title": "Rental",
      "description": "A record of a clothing rental",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "clothing_id": { "type": "string" },
        "clothing_name": { "type": "string" },
        "image_url": { "type": "string" },
        "client_id": { "type": "string" },
        "client_name": { "type": "string" },
        "client_phone": { "type": "string" },
        "size": { "type": "string" },
        "color": { "type": "string" },
        "rental_date": { "type": "string", "format": "date-time" },
        "returned_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "returned"] }
      },
      "required": ["company_id", "clothing_id", "client_name", "size", "color", "status"]
    },
    "Project": {
      "title": "Project",
      "description": "A film, TV, or event production project",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["company_id", "name"]
    },
    "Actor": {
      "title": "Actor",
      "description": "An actor or model participating in a project",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "project_id": { "type": "string" },
        "name": { "type": "string" },
        "weight": { "type": "string" },
        "height": { "type": "string" },
        "shoulder_size": { "type": "string" },
        "waist_size": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["company_id", "project_id", "name"]
    },
    "Shot": {
      "title": "Shot",
      "description": "A specific costume assignment for an actor's shot",
      "type": "object",
      "properties": {
        "company_id": { "type": "string" },
        "project_id": { "type": "string" },
        "actor_id": { "type": "string" },
        "shot_number": { "type": "number" },
        "clothing_item_ids": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["company_id", "project_id", "actor_id", "shot_number"]
    }
  },
  "firestore": {
    "/companies/{companyId}": {
      "schema": "Company",
      "description": "Company accounts"
    },
    "/clothes/{clothId}": {
      "schema": "ClothingItem",
      "description": "Inventory of clothes"
    },
    "/collections/{collectionId}": {
      "schema": "Collection",
      "description": "Curated collections"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Customer database"
    },
    "/rentals/{rentalId}": {
      "schema": "Rental",
      "description": "Rental transactions"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Production projects"
    },
    "/projects/{projectId}/actors/{actorId}": {
      "schema": "Actor",
      "description": "Actors in a project"
    },
    "/projects/{projectId}/actors/{actorId}/shots/{shotId}": {
      "schema": "Shot",
      "description": "Costume shots for an actor"
    }
  }
}
